# Скопируй в .env и заполни реальными значениями.
# .env в git НЕ коммитится — секреты остаются у тебя.

# Токен Telegram-бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# API-ключ Groq. Получить: https://console.groq.com/keys
# Бесплатный тариф: ~2 часа аудио в день + щедрый лимит на Llama 3.3
GROQ_API_KEY=gsk_...

# Лимит на пользователя в сутки (в минутах аудио). 0 = без лимита.
DAILY_USER_LIMIT_MINUTES=30

# Список Telegram ID, которым доступ запрещён (антиспам). Через запятую.
BLACKLIST_USER_IDS=

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Модели Groq
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_LLM_MODEL=llama-3.3-70b-versatile
